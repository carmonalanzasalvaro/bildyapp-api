PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/bildyapp
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
MAIL_FROM=no-reply@bildyapp.local
MAILTRAP_HOST=
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=
SLACK_WEBHOOK_URL=

# Generic storage vars used by the API
STORAGE_ENDPOINT=https://example-r2-endpoint.test
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=bildyapp-files
STORAGE_PUBLIC_BASE_URL=
STORAGE_SIGNED_URL_TTL=900
STORAGE_FORCE_PATH_STYLE=false

# Optional aliases for S3 or R2 compatible providers
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
